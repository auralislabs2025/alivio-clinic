# WhatsApp booking (digits only: country code + number, no spaces or +)
# India: 91 + 10-digit mobile, e.g. 917012377466
VITE_WHATSAPP_NUMBER=917012377466

# Vercel: set Project "Root Directory" to `clinic` (this folder) so `api/contact.js` deploys.
#
# Contact form → email via Resend (set in Vercel Project → Settings → Environment Variables)
# https://resend.com — create API key, then verify a domain for production "from" address.
#
# After changing env vars on Vercel: redeploy (Deployments → … → Redeploy) so serverless picks them up.
#
# send_failed in the browser? Vercel → your deployment → Logs / Observability → find "[contact] Resend error"
# (JSON includes Resend’s message). Common fixes:
# - Using onboarding@resend.dev (default from): Resend may only allow sending TO the email you used to sign up.
#   Set CONTACT_TO_EMAIL to that address for testing, or verify your domain and set RESEND_FROM_EMAIL.
# - Custom RESEND_FROM_EMAIL: domain must be verified in Resend; use "Display Name <user@yourdomain.com>".
RESEND_API_KEY=re_xxxxxxxx
# Optional: defaults to drsree.alivio@gmail.com
CONTACT_TO_EMAIL=drsree.alivio@gmail.com
# Optional: verified domain in Resend for production; if unset, API uses onboarding@resend.dev (test limits)
# RESEND_FROM_EMAIL=Alivio Homoeo Clinic <appointments@yourdomain.com>
