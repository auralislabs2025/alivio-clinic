# WhatsApp booking (digits only: country code + number, no spaces or +)
# India: 91 + 10-digit mobile, e.g. 917012377466
VITE_WHATSAPP_NUMBER=917012377466

# Vercel: set Project "Root Directory" to `clinic` (this folder) so `api/contact.js` deploys.
#
# Contact form → email via Resend (set in Vercel Project → Settings → Environment Variables)
# https://resend.com — create API key, then verify a domain for production "from" address.
RESEND_API_KEY=re_xxxxxxxx
# Optional: defaults to drsree.alivio@gmail.com
CONTACT_TO_EMAIL=drsree.alivio@gmail.com
# Optional: must be a verified domain in Resend (not required for onboarding@resend.dev testing)
# RESEND_FROM_EMAIL=Alivio Homoeo Clinic <appointments@yourdomain.com>
